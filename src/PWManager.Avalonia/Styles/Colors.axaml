<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Background colors — dark warm-gray + teal accent theme -->
  <Color x:Key="AppBg">#121210</Color>
  <Color x:Key="AppBg2">#1A1A18</Color>
  <Color x:Key="CardBg">#1D1D1A</Color>
  <Color x:Key="CardBorder">#2C2C28</Color>
  <Color x:Key="InputBg">#121210</Color>
  <Color x:Key="InputBorder">#2C2C28</Color>
  <Color x:Key="AccentBlue">#3ECAB5</Color>
  <Color x:Key="AccentBlueDark">#2EA89A</Color>
  <Color x:Key="AccentBlueBright">#5DDECE</Color>
  <Color x:Key="TextPrimary">#E8E8E2</Color>
  <Color x:Key="TextSecondary">#888880</Color>
  <Color x:Key="TextMuted">#504C48</Color>
  <Color x:Key="GreenDot">#22C55E</Color>
  <Color x:Key="DangerColor">#E05252</Color>
  <Color x:Key="SuccessColor">#22C55E</Color>
  <Color x:Key="StrengthGreen">#22C55E</Color>
  <Color x:Key="SidebarBg">#121210</Color>
  <Color x:Key="SidebarSelected">#242420</Color>
  <Color x:Key="HeaderBg">#121210</Color>

  <!-- SolidColorBrushes for each -->
  <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBg}"/>
  <SolidColorBrush x:Key="AppBg2Brush" Color="{StaticResource AppBg2}"/>
  <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}"/>
  <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}"/>
  <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBg}"/>
  <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorder}"/>
  <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
  <SolidColorBrush x:Key="AccentBlueDarkBrush" Color="{StaticResource AccentBlueDark}"/>
  <SolidColorBrush x:Key="AccentBlueBrightBrush" Color="{StaticResource AccentBlueBright}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
  <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
  <SolidColorBrush x:Key="GreenDotBrush" Color="{StaticResource GreenDot}"/>
  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
  <SolidColorBrush x:Key="StrengthGreenBrush" Color="{StaticResource StrengthGreen}"/>
  <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBg}"/>
  <SolidColorBrush x:Key="SidebarSelectedBrush" Color="{StaticResource SidebarSelected}"/>
  <SolidColorBrush x:Key="HeaderBgBrush" Color="{StaticResource HeaderBg}"/>

</ResourceDictionary>
