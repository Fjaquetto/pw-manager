<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PWManager.Avalonia.ViewModels"
        xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="PWManager.Avalonia.Views.UnlockView"
        x:DataType="vm:UnlockViewModel"
        Title="PWManager"
        Width="480"
        Height="520"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Background="{StaticResource AppBgBrush}">

  <!-- Outer background gradient -->
  <Grid>
    <Grid.Background>
      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#0C0C0A" Offset="0"/>
        <GradientStop Color="#121210" Offset="0.5"/>
        <GradientStop Color="#1A1A18" Offset="1"/>
      </LinearGradientBrush>
    </Grid.Background>

    <!-- Card -->
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="400"
            Background="{StaticResource CardBgBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="32,24">

      <StackPanel Spacing="0">

        <!-- Window Header (drag area + close) -->
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20"
              PointerPressed="Header_PointerPressed">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Width="28" Height="28" CornerRadius="6"
                    Background="{StaticResource SidebarSelectedBrush}"
                    BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1">
              <material:MaterialIcon Kind="Shield" Width="14" Height="14" Foreground="{StaticResource AccentBlueBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="PWManager" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <Button Grid.Column="2" Classes="icon"
                  Click="CloseButton_Click"
                  VerticalAlignment="Center">
            <material:MaterialIcon Kind="Close" Width="14" Height="14" Foreground="{StaticResource TextSecondaryBrush}"/>
          </Button>
        </Grid>

        <!-- Lock Icon Circle -->
        <Border Width="80" Height="80" CornerRadius="40"
                BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="2"
                HorizontalAlignment="Center" Margin="0,8,0,20">
          <material:MaterialIcon Kind="Lock" Width="36" Height="36" Foreground="{StaticResource AccentBlueBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Title and Subtitle -->
        <TextBlock Text="Unlock"
                   FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Text="Enter your master password to continue."
                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" TextAlignment="Center"
                   Margin="0,0,0,24"/>

        <!-- Password Label -->
        <TextBlock Text="Password"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,8"/>

        <!-- Password Field -->
        <Border Background="{StaticResource InputBgBrush}"
                BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="12,0">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <material:MaterialIcon Grid.Column="0" Kind="Lock" Width="14" Height="14"
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Column="1"
                     Name="PasswordBox"
                     Text="{Binding Password}"
                     PasswordChar="•"
                     Watermark="Enter master password"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Padding="0,10"
                     FontSize="13">
              <TextBox.KeyBindings>
                <KeyBinding Gesture="Return" Command="{Binding UnlockCommand}"/>
              </TextBox.KeyBindings>
            </TextBox>
            <Button Grid.Column="2" Classes="icon"
                    Click="TogglePassword_Click"
                    VerticalAlignment="Center">
              <material:MaterialIcon Kind="Eye" Width="16" Height="16" Foreground="{StaticResource TextSecondaryBrush}"/>
            </Button>
          </Grid>
        </Border>

        <!-- Error Message -->
        <TextBlock Text="{Binding ErrorMessage}"
                   FontSize="12"
                   Foreground="{StaticResource DangerBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"
                   IsVisible="{Binding HasError}"/>

        <!-- Unlock Button (metallic gradient via unlock-btn class) -->
        <Button Classes="unlock-btn"
                Command="{Binding UnlockCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Height="48"
                FontSize="15"
                Margin="0,20,0,0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <material:MaterialIcon Kind="LockOpen" Width="16" Height="16" VerticalAlignment="Center"/>
            <TextBlock Text="Unlock" FontWeight="SemiBold" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

      </StackPanel>
    </Border>
  </Grid>
</Window>
